<Window x:Class="ShaoLu.Views.WindowSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShaoLu.Views" xmlns:viewmodels="clr-namespace:ShaoLu.Viewmodels" d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
        mc:Ignorable="d"
        Title="WindowSettings" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>
        <TreeView x:Name="treeView" >
            
        </TreeView>
        <ContentControl x:Name="contentControl" Grid.Column="1" Content="{Binding SelectedSetItem}" />
    </Grid>
</Window>
