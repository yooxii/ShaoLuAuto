<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:ShaoLu.Models"
                    xmlns:vm="clr-namespace:ShaoLu.Viewmodels"
                    xmlns:conv="clr-namespace:ShaoLu.Converters">

    <!-- App 设置模板 -->
    <DataTemplate DataType="{x:Type vm:AppSettingsViewModel}">
        <StackPanel>
            <TextBlock Text="App 设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="主题：" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" 
                                      SelectedItem="{Binding Theme}" Margin="0,4">
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="Dark"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="字体大小：" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                                     Text="{Binding Font, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- Step 设置模板 -->
    <DataTemplate DataType="{x:Type vm:StepSettingsViewModel}">
        <StackPanel>
            <TextBlock Text="Step 设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="默认超时(s)：" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                                     Text="{Binding DefaultTimeout, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="启用日志：" VerticalAlignment="Center"/>
                <CheckBox Grid.Row="1" Grid.Column="1" 
                                      IsChecked="{Binding EnableLogging}" Margin="0,6,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="日志路径：" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                                     Text="{Binding LogPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>