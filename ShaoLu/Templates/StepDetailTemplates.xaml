<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:VM="clr-namespace:ShaoLu.Viewmodels"
                    xmlns:AutoVM="clr-namespace:ShaoLu.Viewmodels.AutomationStep"
                    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
                    xmlns:lex="http://wpflocalizeextension.codeplex.com"
                    xmlns:conv="clr-namespace:ShaoLu.Converters">

    <!-- 识图步骤的UI -->
    <DataTemplate x:Key="ClickImageStepTemplate" DataType="{x:Type AutoVM:ClickImageStep}">
        <StackPanel Orientation="Vertical">
            <StackPanel>
                <Label Content="{lex:Loc Select_target_pic}" VerticalAlignment="Center" Target="{Binding ElementName=PathTextBlock}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="PathTextBlock"
                           Text="{Binding ImagePath}" 
                           VerticalAlignment="Center" 
                           MinWidth="150"
                           MaxWidth="250"
                           TextWrapping="NoWrap"
                           IsReadOnly="True"
                           ToolTip="{Binding ImagePath}"/>
                    <Button Content="{lex:Loc Select}" Command="{Binding SelectImageCommand}" Margin="3,0,0,0"/>
                    <Button Content="{lex:Loc Edit}" Command="{Binding EditImageCommand}" Margin="3,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,5,0,0">
                <Label Content="{lex:Loc Picture_similarity_threshold}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <wd:NumericBox Value="{Binding SimilarityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        Precision="3"
                        Interval="0.001"
                        Width="70"/>
                    <Slider Value="{Binding SimilarityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        Minimum="0" 
                        Maximum="1" 
                        Width="150"/>
                </StackPanel>
            </StackPanel>
            <StackPanel>
                <StackPanel>
                    <Label Content="{lex:Loc Clicks}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding Clicks, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0"/>
                </StackPanel>
                <StackPanel >
                    <Label Content="{lex:Loc ClickGap}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding ClickGap, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0"
                    MaxWidth="300"
                    Precision="3"
                    Interval="0.01"/>
                </StackPanel>
                <StackPanel >
                    <Label Content="{lex:Loc WaitTime}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding WaitTime, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" 
                    Precision="3" Minimum="0"
                    Interval="0.01"/>
                </StackPanel>
                <StackPanel >
                    <Label Content="{lex:Loc Timeout}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding Timeout, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" 
                    Precision="3" Minimum="0"
                    Interval="0.1"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="FindImageStepTemplate" DataType="{x:Type AutoVM:FindImageStep}">
        <StackPanel>
            <StackPanel>
                <Label Content="{lex:Loc Select_target_pic}" VerticalAlignment="Center" Target="{Binding ElementName=PathTextBlock}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="PathTextBlock"
                           Text="{Binding ImagePath}" 
                           MinWidth="150"
                           MaxWidth="250"
                           TextWrapping="NoWrap"
                           IsReadOnly="True"
                           ToolTip="{Binding ImagePath}"/>
                    <Button Content="{lex:Loc Select}" Command="{Binding SelectImageCommand}" Margin="3,0,0,0"/>
                    <Button Content="{lex:Loc Edit}" Command="{Binding EditImageCommand}" Margin="3,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,5,0,0">
                <Label Content="{lex:Loc Picture_similarity_threshold}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <wd:NumericBox Value="{Binding SimilarityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        Precision="3"
                        Interval="0.001"
                        Width="70"/>
                    <Slider Value="{Binding SimilarityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                        Minimum="0" 
                        Maximum="1" 
                        Width="150"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel>
                <Label Content="{lex:Loc FindTimeInterval}" VerticalAlignment="Center"/>
                <wd:NumericBox Value="{Binding GapTime, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0" Precision="3" Interval="0.1"/>
            </StackPanel>
            <StackPanel>
                <Label Content="{lex:Loc Timeout}" VerticalAlignment="Center"/>
                <wd:NumericBox Value="{Binding Timeout, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0" Precision="3" Interval="0.1"/>
            </StackPanel>
        </StackPanel>
    </DataTemplate>


    <DataTemplate x:Key="ClickImagesStepTemplate" DataType="{x:Type AutoVM:ClickImagesStep}">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Button Content=" + " Command="{Binding AddImageCommand}" Margin="0,0,10,0"/>
                <Button Content=" - " Command="{Binding DelImageCommand}" Margin="0,0,10,0"/>
            </StackPanel>
            <ListBox ItemsSource="{Binding Images}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical">
                            <StackPanel>
                                <Label Content="{lex:Loc Select_target_pic}" VerticalAlignment="Center" Target="{Binding ElementName=PathTextBlock}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="PathTextBlock" Text="{Binding ImagePath}" VerticalAlignment="Center" 
                                           MinWidth="150" MaxWidth="250" TextWrapping="NoWrap" IsReadOnly="True" ToolTip="{Binding ImagePath}"/>
                                    <Button Content="{lex:Loc Select}" Command="{Binding SelectImageCommand}" Margin="3,0,0,0"/>
                                    <Button Content="{lex:Loc Edit}" Command="{Binding EditImageCommand}" Margin="3,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,5,0,0">
                                <Label Content="{lex:Loc Picture_similarity_threshold}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <wd:NumericBox Value="{Binding SimilarityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Precision="3" Interval="0.001" Width="70"/>
                                    <Slider Value="{Binding SimilarityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Minimum="0" Maximum="1" Width="150"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <StackPanel>
                <StackPanel>
                    <Label Content="{lex:Loc Clicks}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding Clicks, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0"/>
                </StackPanel>
                <StackPanel >
                    <Label Content="{lex:Loc ClickGap}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding ClickGap, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0"
                    MaxWidth="300"
                    Precision="3"
                    Interval="0.01"/>
                </StackPanel>
                <StackPanel >
                    <Label Content="{lex:Loc WaitTime}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding WaitTime, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" 
                    Precision="3" Minimum="0"
                    Interval="0.01"/>
                </StackPanel>
                <StackPanel >
                    <Label Content="{lex:Loc Timeout}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding Timeout, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" 
                    Precision="3" Minimum="0"
                    Interval="0.1"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="FindImagesStepTemplate" DataType="{x:Type AutoVM:FindImagesStep}">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <Button Content=" + " Command="{Binding AddImageCommand}" Margin="0,0,10,0"/>
                <Button Content=" - " Command="{Binding DelImageCommand}" Margin="0,0,10,0"/>
            </StackPanel>
            <ListBox ItemsSource="{Binding Images}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel>
                                <Label Content="{lex:Loc Select_target_pic}" VerticalAlignment="Center" Target="{Binding ElementName=PathTextBlock}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="PathTextBlock"
                               Text="{Binding ImagePath}" 
                               MinWidth="150"
                               MaxWidth="250"
                               TextWrapping="NoWrap"
                               IsReadOnly="True"
                               ToolTip="{Binding ImagePath}"/>
                                    <Button Content="{lex:Loc Select}" Command="{Binding SelectImageCommand}" Margin="3,0,0,0"/>
                                    <Button Content="{lex:Loc Edit}" Command="{Binding EditImageCommand}" Margin="3,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,5,0,0">
                                <Label Content="{lex:Loc Picture_similarity_threshold}" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <wd:NumericBox Value="{Binding SimilarityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                            Precision="3"
                            Interval="0.001"
                            Width="70"/>
                                    <Slider Value="{Binding SimilarityThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                            Minimum="0" 
                            Maximum="1" 
                            Width="150"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel>
                <StackPanel>
                    <Label Content="{lex:Loc FindTimeInterval}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding GapTime, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0" Precision="3" Interval="0.1"/>
                </StackPanel>
                
                <StackPanel>
                    <Label Content="{lex:Loc Timeout}" VerticalAlignment="Center"/>
                    <wd:NumericBox Value="{Binding Timeout, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0" Precision="3" Interval="0.1"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <!-- 输入文字步骤的UI -->
    <DataTemplate x:Key="TextStepTemplate" DataType="{x:Type AutoVM:TypeTextStep}">
        <StackPanel Orientation="Vertical">
            <StackPanel VerticalAlignment="Center">
                <Label Content="{lex:Loc Type_text}" VerticalAlignment="Center"/>
                <TextBox Text="{Binding TextToType, UpdateSourceTrigger=LostFocus}" 
                     MinWidth="150"/>
            </StackPanel>
            <StackPanel VerticalAlignment="Center">
                <Label Content="{lex:Loc DelayBetweenKeys}" VerticalAlignment="Center"/>
                <wd:NumericBox Value="{Binding DelayBetweenKeys, UpdateSourceTrigger=LostFocus}" MinWidth="200" HorizontalAlignment="Left" Minimum="0" Precision="3" Interval="0.01"/>
            </StackPanel>
        </StackPanel>
    </DataTemplate>


    <DataTemplate x:Key="PopupStepTemplate" DataType="{x:Type AutoVM:PopupStep}">
        <StackPanel>
            <StackPanel VerticalAlignment="Center">
                <Label Content="{lex:Loc Title}" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Title, UpdateSourceTrigger=LostFocus}" 
                     MinWidth="150"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel VerticalAlignment="Center">
                <Label Content="{lex:Loc PopupText}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox Text="{Binding PopupText, UpdateSourceTrigger=LostFocus}" 
                               MinWidth="150"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                               
                    <Button Content="{lex:Loc Font}" Command="{Binding FontSelectCommand}" Margin="3,0,0,0"/>
                    <Button Content="{lex:Loc Color}" Command="{Binding ColorSelectCommand}" Margin="3,0,0,0"/>
                </StackPanel>
            </StackPanel>
            <StackPanel VerticalAlignment="Center">
                <Label Content="{lex:Loc PopupType}" VerticalAlignment="Center"/>
                <ComboBox SelectedValue="{Binding PopupType, UpdateSourceTrigger=LostFocus}" 
                     ItemsSource="{Binding PopupTypes}"
                     MinWidth="150"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="❓"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="Error">
                                                    <Setter Property="Text" Value="❌"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Warning">
                                                    <Setter Property="Text" Value="⚠️"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Information">
                                                    <Setter Property="Text" Value="ℹ️"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Question">
                                                    <Setter Property="Text" Value="❓"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="None">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <GroupBox Header="{lex:Loc Buttons}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content=" + " Command="{Binding AddButtonCommand}" Margin="0,0,10,0"/>
                        <Button Content=" - " Command="{Binding DelButtonCommand}" Margin="0,0,10,0"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding PopupButtons.Buttons}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type VM:PopupButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Text="{Binding DisplayText, UpdateSourceTrigger=LostFocus}" 
                                             MinWidth="120"
                                             Margin="0,0,10,0"
                                             VerticalAlignment="Center"/>
                                    <ComboBox Text="{Binding Value}" 
                                              MinWidth="150"
                                              ItemsSource="{Binding DefaultValues}"
                                              Margin="0,0,10,0"
                                              IsEditable="True"
                                              VerticalAlignment="Center">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>
        </StackPanel>
    </DataTemplate>

    <conv:StepTemplateSelector x:Key="StepDetailSelector"
                     ClickImageTemplate="{StaticResource ClickImageStepTemplate}"
                     FindImageTemplate="{StaticResource FindImageStepTemplate}"
                     ClickImagesTemplate="{StaticResource ClickImagesStepTemplate}"
                     FindImagesTemplate="{StaticResource FindImagesStepTemplate}"
                     TextTemplate="{StaticResource TextStepTemplate}"
                     PopupTemplate="{StaticResource PopupStepTemplate}"/>
</ResourceDictionary>