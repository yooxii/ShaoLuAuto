<Window x:Class="ShaoLu.Views.WindowEditImage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        lex:ResxLocalizationProvider.DefaultAssembly="ShaoLu"
        lex:ResxLocalizationProvider.DefaultDictionary="Strings"
        mc:Ignorable="d"
        xmlns:local="clr-namespace:ShaoLu.Views"
        xmlns:viewmodels="clr-namespace:ShaoLu.Viewmodels"
        d:DataContext="{d:DesignInstance Type=viewmodels:EditImageViewModel}"
        Title="{lex:Loc EditImageTitle}" Height="450" Width="800">
    <!--xmlns:imgtool="clr-namespace:ImageTool"-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <wd:WDScrollViewer HorizontalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <wd:CropImage x:Name="EditImage" Margin="5" Source="{Binding ImgSrc}"/>
                <Image x:Name="PreviewImage" Margin="5" Grid.Column="2" Source="{Binding ImgDst}" Stretch="Uniform"/>
            </Grid>
        </wd:WDScrollViewer>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button x:Name="CropImage" Margin="5" Content="{lex:Loc Crop}" Click="CropImage_Click"/>
            <Button x:Name="SaveImage" Margin="5" Grid.Column="1" Content="{lex:Loc Save}" Click="SaveImage_Click"/>
            <Button x:Name="Cancel" Margin="5" Grid.Column="2" Content="{lex:Loc Cancel}" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
