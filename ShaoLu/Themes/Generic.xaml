<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ShaoLu.Controls"
    xmlns:conv="clr-namespace:ShaoLu.Converters">
    
    <Style x:Key="ScreenCutRectangleStyle" TargetType="Rectangle">
        <Setter Property="Fill" Value="#80000000" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>
    <SolidColorBrush x:Key="PrimaryNormalSolidColorBrush" Color="#3498DB" />

    <Style
        TargetType="{x:Type local:MultiCropImage}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:MultiCropImage}">
                    <Grid x:Name="PART_RootGrid" ClipToBounds="True" Background="#FF1E1E1E">
                        <!-- 视图变换层：承载缩放和平移 -->
                        <Canvas x:Name="PART_ViewCanvas" RenderTransformOrigin="0,0">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="PART_ScaleTransform"/>
                                    <TranslateTransform x:Name="PART_TranslateTransform"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>

                            <!-- 原图背景 -->
                            <Rectangle x:Name="PART_ImageRect" Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" 
                       Height="{Binding ActualHeight, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Canvas>

                        <!-- 遮罩层（保持原有四矩形结构，但需跟随视图变换或独立计算） -->
                        <Rectangle x:Name="PART_RectangleLeft" Style="{DynamicResource ScreenCutRectangleStyle}" />
                        <Rectangle x:Name="PART_RectangleTop" Style="{DynamicResource ScreenCutRectangleStyle}" />
                        <Rectangle x:Name="PART_RectangleRight" Style="{DynamicResource ScreenCutRectangleStyle}" />
                        <Rectangle x:Name="PART_RectangleBottom" Style="{DynamicResource ScreenCutRectangleStyle}" />

                        <!-- 裁剪框层：支持独立旋转 + 整体平移 -->
                        <Canvas x:Name="PART_CropCanvas">
                            <Border x:Name="PART_Border" Background="Transparent" 
                    BorderBrush="{DynamicResource PrimaryNormalSolidColorBrush}" 
                    BorderThickness="2" Cursor="SizeAll"
                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <RotateTransform x:Name="PART_RotateTransform" Angle="0"/>
                                </Border.RenderTransform>
                            </Border>

                            <!-- 新增：旋转手柄 -->
                            <Ellipse x:Name="PART_RotateHandle" Width="16" Height="16" Fill="White" Stroke="Black"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-24,0,0"
                     Cursor="Hand" ToolTip="旋转裁剪框"/>

                            <!-- 新增：复位按钮 -->
                            <Button x:Name="PART_ResetRotationBtn" Content="↺" Width="16" Height="16" FontSize="10"
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-44,0,0"
                    Opacity="0.8" ToolTip="复位旋转"/>
                        </Canvas>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
