<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
                    xmlns:lex="http://wpflocalizeextension.codeplex.com"
                    xmlns:models="clr-namespace:ShaoLu.Models"
                    xmlns:vm="clr-namespace:ShaoLu.Viewmodels"
                    xmlns:conv="clr-namespace:ShaoLu.Converters">

    <!-- App 设置模板 -->
    <DataTemplate DataType="{x:Type vm:AppSettingsViewModel}">
        <StackPanel>
            <TextBlock Text="App 设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{lex:Loc Theme}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" SelectedItem="{Binding Theme}" Margin="0,4">
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="Dark"/>
                </ComboBox>

                <Grid Grid.ColumnSpan="2" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{lex:Loc Font}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Font.FontFamily, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>
                    </Grid>
                    
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{lex:Loc FontSize}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding Font.FontSize, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>
                    </Grid>

                    <Button Grid.Column="3" Content="..."/>
                </Grid>
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- Step 设置模板 -->
    <DataTemplate DataType="{x:Type vm:StepSettingsViewModel}">
        <StackPanel>
            <TextBlock Text="Step 设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{lex:Loc ShowErrorPopup}" VerticalAlignment="Center"/>
                <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding ShowErrorPopup}" Margin="0,6,0,0"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="日志路径：" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="" Margin="0,4"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>