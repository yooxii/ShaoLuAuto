<Window x:Class="ShaoLu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
        lex:ResxLocalizationProvider.DefaultAssembly="ShaoLu"
        lex:ResxLocalizationProvider.DefaultDictionary="Strings"
        xmlns:local="clr-namespace:ShaoLu"
        xmlns:viewmodel="clr-namespace:ShaoLu.Viewmodels"
        xmlns:conv="clr-namespace:ShaoLu.Converters"
        d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
        mc:Ignorable="d"
        Title="{lex:Loc AppTitle}" Height="600" Width="1000">

    <Window.Resources>
        <ResourceDictionary>
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Templates/StepSummaryTemplates.xaml"/>
                <ResourceDictionary Source="/Templates/StepDetailTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu>
            <MenuItem x:Name="File" Header="{lex:Loc}">
                <MenuItem x:Name="New" Header="{lex:Loc}"/>
                <MenuItem x:Name="Open" Header="{lex:Loc}" Click="Open_Click"/>
                <MenuItem x:Name="Save" Header="{lex:Loc Save}" Click="Save_Click"/>
            </MenuItem>
            <MenuItem x:Name="Setting" Header="{lex:Loc}">
            </MenuItem>
            <MenuItem x:Name="Language" Header="{lex:Loc}">
                <MenuItem x:Name="English" Tag="en-US"  Header="{lex:Loc}" IsChecked="{Binding English}" Click="Language_Click"/>
                <MenuItem x:Name="SimplifiedChinese" Tag="zh-CN" Header="{lex:Loc}" IsChecked="{Binding Simplified}" Click="Language_Click"/>
                <MenuItem x:Name="TraditionalChinese" Tag="zh-TW" Header="{lex:Loc}" IsChecked="{Binding Tranditional}" Click="Language_Click"/>
            </MenuItem>
            <MenuItem x:Name="Quit" Header="{lex:Loc}" Click="Quit_Click"/>
            <!--<MenuItem Header="测试裁剪" Click="TestCrop_Click"/>-->
        </Menu> <!--菜单-->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition />
                    <ColumnDefinition Width="10"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnAddStep" Content="{lex:Loc}" Grid.Column="1" Margin="3" Command="{Binding AddImageStepCommand}"/>
                <Button x:Name="BtnDelStep" Content="{lex:Loc}" Grid.Column="3" Margin="3" Click="BtnDelStep_Click"/>
            </Grid> <!--步骤按钮-->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="400"/>
                    <ColumnDefinition Width="3"/>
                    <ColumnDefinition Width="Auto" MinWidth="200"/>
                </Grid.ColumnDefinitions>
                <GroupBox Header="{lex:Loc StepsBox}" Margin="3">
                    <!--<ListBox x:Name="StepsListBox" ItemsSource="{Binding AutomationStepBases}" SelectedItem="{Binding SelectedStep, Mode=TwoWay}" Margin="3">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}" ContentTemplateSelector="{StaticResource StepSummarySelector}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>-->
                    <DataGrid x:Name="StepsBox" ItemsSource="{Binding AutomationStepBases}" SelectionMode="Extended" SelectedItem="{Binding SelectedStep}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding LineNo}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="{lex:Loc StepName}" Binding="{Binding Name, UpdateSourceTrigger=LostFocus}" />
                            <DataGridComboBoxColumn Header="{lex:Loc StepType}" SelectedItemBinding="{Binding Type}" ItemsSource="{Binding Source={StaticResource StepTypeValues}}"/>
                            <DataGridTextColumn Header="{lex:Loc StepDescription}" Binding="{Binding Description}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
                <GridSplitter Grid.Column="1" Width="3" Margin="0,3,0,3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#FFDDDDDD" />
                <GroupBox Header="{lex:Loc StepDetails}" Margin="3" Grid.Column="2">
                    <!-- 当 SelectedStep 为 null 时，可以显示提示文本 -->
                    <Grid>
                        <ContentControl Content="{Binding SelectedStep}" 
                        ContentTemplateSelector="{StaticResource StepDetailSelector}" />

                        <!-- 可选：如果没有选中项，显示提示信息 -->
                        <TextBlock Text="{lex:Loc NoSelectionHint}" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Visibility="{Binding SelectedStep, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </Grid>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="2" Margin="5 0 5 5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnRun" Content="{lex:Loc}" Margin="3" Command="{Binding RunCommand}"/>
                <Button x:Name="BtnStop" Grid.Column="1" Content="{lex:Loc}" Margin="3" Command="{Binding StopCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
